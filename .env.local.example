# Shopify Storefront API (public - peut être exposé côté client)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=vztmja-iy.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token_here

# Shopify API Version
SHOPIFY_API_VERSION=2025-01

# Code promo -15% du calculateur (lu côté serveur, injecté dans cartCreate et le cart permalink — jamais affiché)
DISCOUNT_CODE=PROMO-APP-CALCULATEUR

# Clé privée Klaviyo (serveur uniquement, jamais NEXT_PUBLIC_) — événement
# "Estimation calculateur demandée" envoyé après chaque estimation.
# Absente : l'envoi est ignoré avec un warning, l'estimation aboutit quand même.
KLAVIYO_PRIVATE_API_KEY=pk_your_klaviyo_private_key

# URL de l'application (généré automatiquement par Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000